create or replace function mmovementsmonthyear(year int, month int, iduser int, typecategories text)
returns table(
  id int,
  description text,
  worth numeric,
  fecha date,
  state text,
  cuenta text,
  categoria text,
  worthAndCoin text
)
language sql
as $$
  select movements.id, movements.description, movements.worth, movements.fecha, movements.state, account.description as "cuenta", categories.description as "categoria", (users.currency || ' ' || movements.worth) as worthAndCoin from movements
  inner join account on account.id=movements."idAccount"
  inner join users on users.id = account.user_id
  inner join categories on categories.id = movements."idCategories"
  where categories.type = typecategories and date_part('year', movements.fecha)=year and date_part('month', movements.fecha)=month and users.id = iduser
$$;